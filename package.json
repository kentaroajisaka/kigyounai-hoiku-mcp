{
  "name": "kigyounai-hoiku-mcp",
  "version": "0.3.0",
  "description": "MCP server for Japanese company-led childcare (企業主導型保育) — laws, 実施要綱, 監督基準, FAQ, 通知",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "kigyounai-hoiku-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "childcare",
    "hoiku",
    "kigyounai",
    "japan",
    "law",
    "e-gov",
    "claude"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "pdfjs-dist": "^4.10.38",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
